{
  "manifest_version": 3,
  "name": "PlanYT - Youtube Playlist Planner & Progress Tracker",
  "short_name": "PlanYT",
  "version": "1.2.2",
  "description": "Your Youtube, planned.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://yt-extension-z6so.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube-integration.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon32.png"
      ],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
