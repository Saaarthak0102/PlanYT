{
   "action": {
      "default_icon": {
         "16": "assets/icon16.png",
         "32": "assets/icon32.png"
      },
      "default_popup": "popup/popup.html"
   },
   "background": {
      "service_worker": "background/background.js"
   },
   "content_scripts": [ {
      "js": [ "content/progress-utils.js", "content/progress-widget.js", "content/youtube-integration.js" ],
      "matches": [ "https://www.youtube.com/*" ],
      "run_at": "document_end"
   } ],
   "default_locale": "en",
   "description": "__MSG_extensionDescription__",
   "host_permissions": [ "https://www.youtube.com/*", "https://yt-extension-z6so.vercel.app/*" ],
   "icons": {
      "128": "assets/icon128.png",
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "PlanYT - Youtube Playlist Planner & Progress Tracker",
   "permissions": [ "storage" ],
   "short_name": "PlanYT",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.1",
   "web_accessible_resources": [ {
      "matches": [ "https://www.youtube.com/*" ],
      "resources": [ "assets/icon32.png" ]
   } ]
}